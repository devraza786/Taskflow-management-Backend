// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  starter
  business
  enterprise
}

enum Role {
  admin
  manager
  team_head
  employee
}

enum UserStatus {
  active
  inactive
  suspended
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
  cancelled
}

enum TaskStatus {
  todo
  in_progress
  review
  blocked
  done
  archived
}

enum TaskPriority {
  critical
  high
  medium
  low
}

enum AssigneeRole {
  primary
  reviewer
  watcher
}

enum DependencyType {
  blocks
  blocked_by
  related
}

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  plan        Plan     @default(free)
  maxUsers    Int      @default(10) @map("max_users")
  logoUrl     String?  @map("logo_url")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  users       User[]
  departments Department[]
  teams       Team[]
  projects    Project[]
  tasks       Task[]
  auditLogs   AuditLog[]

  @@map("organizations")
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  orgId          String     @map("org_id") @db.Uuid
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email          String     @unique @db.VarChar(320)
  passwordHash   String?    @map("password_hash")
  name           String     @db.VarChar(255)
  avatarUrl      String?    @map("avatar_url")
  role           Role
  status         UserStatus @default(active)
  timezone       String     @default("UTC") @db.VarChar(100)
  preferences    Json       @default("{}")
  lastLoginAt    DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz

  managedDepartments Department[] @relation("Manager")
  teamsManaged       Team[]       @relation("TeamHead")
  teams              TeamMember[]
  projectsOwned      Project[]
  tasksCreated       Task[]       @relation("CreatedBy")
  tasksAssigned      Task[]       @relation("AssignedTo")
  tasksReviewed      Task[]       @relation("ReviewedBy")
  taskAssignees      TaskAssignee[]
  comments           Comment[]
  attachments        Attachment[]
  notifications      Notification[]
  auditLogs          AuditLog[]   @relation("Actor")

  @@map("users")
}

model Department {
  id           String      @id @default(uuid()) @db.Uuid
  orgId        String      @map("org_id") @db.Uuid
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String      @db.VarChar(255)
  managerId    String?     @map("manager_id") @db.Uuid
  manager      User?       @relation("Manager", fields: [managerId], references: [id])
  parentDeptId String?     @map("parent_dept_id") @db.Uuid
  parentDept   Department? @relation("SubDepartments", fields: [parentDeptId], references: [id])
  subDepartments Department[] @relation("SubDepartments")
  teams        Team[]
  projects     Project[]
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz

  @@map("departments")
}

model Team {
  id          String       @id @default(uuid()) @db.Uuid
  orgId       String       @map("org_id") @db.Uuid
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deptId      String?      @map("dept_id") @db.Uuid
  department  Department?  @relation(fields: [deptId], references: [id])
  name        String       @db.VarChar(255)
  teamHeadId  String?      @map("team_head_id") @db.Uuid
  teamHead    User?        @relation("TeamHead", fields: [teamHeadId], references: [id])
  description String?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  members     TeamMember[]
  tasks       Task[]

  @@map("teams")
}

model TeamMember {
  teamId   String   @map("team_id") @db.Uuid
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId   String   @map("user_id") @db.Uuid
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz

  @@id([teamId, userId])
  @@map("team_members")
}

model Project {
  id           String        @id @default(uuid()) @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deptId       String?       @map("dept_id") @db.Uuid
  department   Department?   @relation(fields: [deptId], references: [id])
  name         String        @db.VarChar(255)
  description  String?
  ownerId      String?       @map("owner_id") @db.Uuid
  owner        User?         @relation(fields: [ownerId], references: [id])
  status       ProjectStatus @default(planning)
  startDate    DateTime?     @map("start_date") @db.Date
  endDate      DateTime?     @map("end_date") @db.Date
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  tasks        Task[]

  @@map("projects")
}

model Task {
  id             String       @id @default(uuid()) @db.Uuid
  orgId          String       @map("org_id") @db.Uuid
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId      String?      @map("project_id") @db.Uuid
  project        Project?     @relation(fields: [projectId], references: [id])
  teamId         String?      @map("team_id") @db.Uuid
  team           Team?        @relation(fields: [teamId], references: [id])
  parentTaskId   String?      @map("parent_task_id") @db.Uuid
  parentTask     Task?        @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks       Task[]       @relation("SubTasks")
  title          String       @db.VarChar(500)
  description    String?
  status         TaskStatus   @default(todo)
  priority       TaskPriority @default(medium)
  createdBy      String       @map("created_by") @db.Uuid
  creator        User         @relation("CreatedBy", fields: [createdBy], references: [id])
  assignedTo     String?      @map("assigned_to") @db.Uuid
  assignee       User?        @relation("AssignedTo", fields: [assignedTo], references: [id])
  reviewedBy     String?      @map("reviewed_by") @db.Uuid
  reviewer       User?        @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  dueDate        DateTime?    @map("due_date") @db.Timestamptz
  startDate      DateTime?    @map("start_date") @db.Timestamptz
  completedAt    DateTime?    @map("completed_at") @db.Timestamptz
  estimatedHours Decimal?     @map("estimated_hours") @db.Decimal(6, 2)
  actualHours    Decimal?     @map("actual_hours") @db.Decimal(6, 2)
  tags           String[]
  metadata       Json         @default("{}")
  position       Int          @default(0)
  isRecurring    Boolean      @default(false) @map("is_recurring")
  recurrenceRule String?      @map("recurrence_rule")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz

  assignees      TaskAssignee[]
  dependencies   TaskDependency[] @relation("TaskDependencies")
  dependents     TaskDependency[] @relation("TaskDependents")
  comments       Comment[]
  attachments    Attachment[]

  @@map("tasks")
}

model TaskAssignee {
  taskId     String       @map("task_id") @db.Uuid
  task       Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String       @map("user_id") @db.Uuid
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       AssigneeRole @default(primary)
  assignedAt DateTime     @default(now()) @map("assigned_at") @db.Timestamptz

  @@id([taskId, userId])
  @@map("task_assignees")
}

model TaskDependency {
  taskId       String         @map("task_id") @db.Uuid
  task         Task           @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnId  String         @map("depends_on_id") @db.Uuid
  dependsOnTask Task          @relation("TaskDependents", fields: [dependsOnId], references: [id], onDelete: Cascade)
  type         DependencyType @default(blocks)

  @@id([taskId, dependsOnId])
  @@map("task_dependencies")
}

model Comment {
  id         String    @id @default(uuid()) @db.Uuid
  taskId     String    @map("task_id") @db.Uuid
  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  body       String
  parentId   String?   @map("parent_id") @db.Uuid
  parent     Comment?  @relation("Thread", fields: [parentId], references: [id])
  replies    Comment[] @relation("Thread")
  mentions   String[]  @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  @@map("comments")
}

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  taskId     String   @map("task_id") @db.Uuid
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy String?  @map("uploaded_by") @db.Uuid
  uploader   User?    @relation(fields: [uploadedBy], references: [id])
  filename   String   @db.VarChar(500)
  fileUrl    String   @map("file_url")
  fileSize   BigInt?  @map("file_size")
  mimeType   String?  @map("mime_type") @db.VarChar(200)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("attachments")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(100)
  title     String?  @db.VarChar(500)
  body      String?
  data      Json     @default("{}")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("notifications")
}

model AuditLog {
  id         String       @id @default(uuid()) @db.Uuid
  orgId      String       @map("org_id") @db.Uuid
  organization Organization @relation(fields: [orgId], references: [id])
  actorId    String       @map("actor_id") @db.Uuid
  actor      User         @relation("Actor", fields: [actorId], references: [id])
  action     String       @db.VarChar(200)
  entityType String?      @map("entity_type") @db.VarChar(100)
  entityId   String?      @map("entity_id") @db.Uuid
  oldValue   Json?        @map("old_value")
  newValue   Json?        @map("new_value")
  ipAddress  String?      @map("ip_address") @db.VarChar(50)
  userAgent  String?      @map("user_agent")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz

  @@map("audit_logs")
}
